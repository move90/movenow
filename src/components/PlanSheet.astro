---
import { site } from '../config';
---

<!-- SIGNATURE: the printed plan sheet -->
<div class="sheet-stage">
  <div class="sheet" aria-label="Example printed exercise plan">
    <div class="sheet-head">
      <span class="sheet-clinic">Your Clinic</span>
      <span class="sheet-tag">EXERCISE PLAN</span>
    </div>
    <div class="sheet-meta">
      <span>Patient&nbsp;<b>—</b></span>
      <span>Date&nbsp;<b>—</b></span>
      <span>Plan&nbsp;<b>3 exercises</b></span>
    </div>

    <div class="ex">
      <div class="ex-thumb">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="2.2"/><path d="M12 7v7M12 14l-3 5M12 14l3 5M8 10h8"/></svg>
      </div>
      <div class="ex-body">
        <div class="ex-name">Standing hip abduction</div>
        <div class="ex-note">Slow, controlled · hold the wall</div>
      </div>
      <div class="ex-dose">3×12</div>
    </div>

    <div class="ex">
      <div class="ex-thumb">
        <svg viewBox="0 0 24 24"><circle cx="7" cy="6" r="2"/><path d="M7 8v5l-2 6M7 13l4 2 4-5M11 15l1 5"/></svg>
      </div>
      <div class="ex-body">
        <div class="ex-name">Seated knee extension</div>
        <div class="ex-note">Both legs · pause at the top</div>
      </div>
      <div class="ex-dose">3×15</div>
    </div>

    <div class="ex">
      <div class="ex-thumb">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="2.2"/><path d="M12 7v6M8 19l4-6 4 6M9 11h6"/></svg>
      </div>
      <div class="ex-body">
        <div class="ex-name">Heel raises</div>
        <div class="ex-note">Daily · add support if needed</div>
      </div>
      <div class="ex-dose">2×20</div>
    </div>

    <div class="sheet-foot">
      <span>Made with <b>{site.productName}</b></span>
      <span>Page 1 / 1</span>
    </div>
  </div>
</div>

<style>
  .sheet-stage{display:flex;justify-content:center;perspective:1400px}
  .sheet{
    width:100%;max-width:380px;background:var(--sheet);border:1px solid var(--line);
    border-radius:14px;box-shadow:var(--shadow);overflow:hidden;
    transform:rotate(1.4deg);transition:transform .4s cubic-bezier(.2,.7,.2,1);
  }
  .sheet:hover{transform:rotate(0deg) translateY(-4px)}
  .sheet-head{
    display:flex;align-items:center;justify-content:space-between;
    padding:16px 18px;border-bottom:1px solid var(--line);
  }
  .sheet-clinic{font-family:'Bricolage Grotesque',sans-serif;font-weight:700;font-size:15px}
  .sheet-tag{font-family:'Space Mono',monospace;font-size:10.5px;color:var(--ink-soft);
    border:1px solid var(--line);padding:3px 8px;border-radius:6px}
  .sheet-meta{padding:13px 18px 6px;font-size:12px;color:var(--ink-soft);
    display:flex;gap:18px}
  .sheet-meta span b{color:var(--ink);font-weight:600}
  .ex{display:flex;gap:13px;padding:13px 18px;border-top:1px solid var(--line);align-items:center}
  .ex-thumb{
    flex:none;width:52px;height:52px;border-radius:9px;background:var(--paper-2);
    display:flex;align-items:center;justify-content:center;
  }
  .ex-thumb svg{width:30px;height:30px;stroke:var(--accent-deep);stroke-width:1.6;fill:none;
    stroke-linecap:round;stroke-linejoin:round}
  .ex-body{flex:1;min-width:0}
  .ex-name{font-size:14px;font-weight:600;color:var(--ink)}
  .ex-note{font-size:11.5px;color:var(--ink-soft)}
  .ex-dose{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--accent-deep);white-space:nowrap}
  .sheet-foot{padding:11px 18px;border-top:1px solid var(--line);
    font-size:10.5px;color:var(--ink-soft);display:flex;justify-content:space-between;align-items:center}
  .sheet-foot b{font-family:'Bricolage Grotesque',sans-serif;color:var(--ink-soft);font-weight:700}

  @media(max-width:860px){
    .sheet-stage{order:-1}
    .sheet{transform:rotate(0deg);max-width:340px}
  }
</style>
